# ---------------------------------------------------------------------------
# POLYMIND CHINESE — biến môi trường mẫu
# Copy sang .env.local và điền giá trị thật. KHÔNG commit .env.local.
# ---------------------------------------------------------------------------

# URL gốc của app (dùng cho redirect invite/reset password, link trong email)
# Local: http://localhost:3000 · Production: https://<project>.vercel.app
NEXT_PUBLIC_APP_URL=

# Supabase — lấy từ `npx supabase status` (local) hoặc Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — CHỈ dùng ở server (admin client: invite user, khóa tài khoản).
# TUYỆT ĐỐI không đặt tiền tố NEXT_PUBLIC_ và không import vào Client Component.
SUPABASE_SERVICE_ROLE_KEY=

# Secret bảo vệ route cron (/api/cron/*). Sinh chuỗi ngẫu nhiên đủ dài.
CRON_SECRET=

# --- Phase 2 (AI) — chưa dùng ở v1 -------------------------------------------
# AI không thuộc phạm vi v1 (quyết định D-7, xem docs/07-product-backlog.md B-1).
# Khi làm phase 2: nạp key qua biến môi trường này, KHÔNG hard-code vào source.
GEMINI_API_KEY=
